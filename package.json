{
  "name": "stellaris-writing-obsidian",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -b && vite build && cp manifest.json dist/manifest.json && cp src/App.css dist/styles.css && mkdir -p dist/assets && cp src/assets/*.png dist/assets/",
    "lint": "oxlint",
    "package": "npm run build"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "builtin-modules": "^5.3.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.13.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
